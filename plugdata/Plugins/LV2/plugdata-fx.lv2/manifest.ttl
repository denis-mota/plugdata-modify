@prefix lv2:   <http://lv2plug.in/ns/lv2core#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix pset:  <http://lv2plug.in/ns/ext/presets#> .
@prefix state: <http://lv2plug.in/ns/ext/state#> .
@prefix ui:    <http://lv2plug.in/ns/extensions/ui#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .

<https://github.com/timothyschoen/plugdata-fx>
	a lv2:Plugin ;
	lv2:binary <libplugdata-fx.so> ;
	rdfs:seeAlso <dsp.ttl> .

<https://github.com/timothyschoen/plugdata-fx:UI>
	a ui:X11UI ;
	lv2:binary <libplugdata-fx.so> ;
	rdfs:seeAlso <ui.ttl> .

<https://github.com/timothyschoen/plugdata-fx:preset1>
	a pset:Preset ;
	lv2:appliesTo <https://github.com/timothyschoen/plugdata-fx> ;
	rdfs:label "Default Preset" ;
	state:state [ <https://github.com/timothyschoen/plugdata-fx:Program> "0"^^xsd:int ; ] .

<https://github.com/timothyschoen/plugdata-fx:preset2>
	a pset:Preset ;
	lv2:appliesTo <https://github.com/timothyschoen/plugdata-fx> ;
	rdfs:label "LIRA-8" ;
	state:state [ <https://github.com/timothyschoen/plugdata-fx:Program> "1"^^xsd:int ; ] .

<https://github.com/timothyschoen/plugdata-fx:preset3>
	a pset:Preset ;
	lv2:appliesTo <https://github.com/timothyschoen/plugdata-fx> ;
	rdfs:label "AlmondOrgan" ;
	state:state [ <https://github.com/timothyschoen/plugdata-fx:Program> "2"^^xsd:int ; ] .

<https://github.com/timothyschoen/plugdata-fx:preset4>
	a pset:Preset ;
	lv2:appliesTo <https://github.com/timothyschoen/plugdata-fx> ;
	rdfs:label "MiniMock" ;
	state:state [ <https://github.com/timothyschoen/plugdata-fx:Program> "3"^^xsd:int ; ] .

<https://github.com/timothyschoen/plugdata-fx:preset5>
	a pset:Preset ;
	lv2:appliesTo <https://github.com/timothyschoen/plugdata-fx> ;
	rdfs:label "Castafiore" ;
	state:state [ <https://github.com/timothyschoen/plugdata-fx:Program> "4"^^xsd:int ; ] .

<https://github.com/timothyschoen/plugdata-fx:preset6>
	a pset:Preset ;
	lv2:appliesTo <https://github.com/timothyschoen/plugdata-fx> ;
	rdfs:label "Bulgroz" ;
	state:state [ <https://github.com/timothyschoen/plugdata-fx:Program> "5"^^xsd:int ; ] .

<https://github.com/timothyschoen/plugdata-fx:preset7>
	a pset:Preset ;
	lv2:appliesTo <https://github.com/timothyschoen/plugdata-fx> ;
	rdfs:label "Pong" ;
	state:state [ <https://github.com/timothyschoen/plugdata-fx:Program> "6"^^xsd:int ; ] .

